# Copy this file to .env (which is git-ignored) and fill in your values.
# Used by docker-compose.test.yml and run-quench.js.

# Your Foundry VTT license key (from foundryvtt.com)
FOUNDRY_LICENSE_KEY=your-license-key-here

# Password you want set for the Foundry admin panel
FOUNDRY_ADMIN_KEY=your-admin-password-here

# Your Foundry account credentials (used by felddy/foundryvtt to download Foundry)
FOUNDRY_USERNAME=your-foundry-username
FOUNDRY_PASSWORD=your-foundry-password

# Optional: URL to a locally-downloaded Foundry release zip (avoids repeated downloads)
# FOUNDRY_RELEASE_URL=https://foundryvtt.s3.amazonaws.com/releases/12.x.x/FoundryVTT-12.x.x.zip

# Optional: set to "true" to keep test artifacts visible after a test run
# TRAVELER_KEEP_WORLD=false
