<style>
  .traveler-encounter-dialog .window-content {
    padding: 16px;
  }
  .traveler-encounter-dialog .enc-header {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    margin-bottom: 14px;
  }
  .traveler-encounter-dialog .enc-portrait {
    width: 72px;
    height: 72px;
    object-fit: cover;
    border-radius: 8px;
    border: 2px solid var(--color-border-light-2);
    flex-shrink: 0;
  }
  .traveler-encounter-dialog .enc-portrait-placeholder {
    width: 72px;
    height: 72px;
    border-radius: 8px;
    border: 2px dashed var(--color-border-light-2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2em;
    color: var(--color-text-dark-secondary);
    flex-shrink: 0;
  }
  .traveler-encounter-dialog .enc-info {
    flex: 1;
  }
  .traveler-encounter-dialog .enc-name {
    font-size: 1.2em;
    font-weight: bold;
    margin: 0 0 4px;
  }
  .traveler-encounter-dialog .enc-meta {
    font-size: 0.82em;
    color: var(--color-text-dark-secondary);
    line-height: 1.6;
  }
  .traveler-encounter-dialog .enc-regen-badge {
    display: inline-block;
    font-size: 0.75em;
    background: var(--color-bg-option);
    border-radius: 4px;
    padding: 1px 6px;
    margin-top: 4px;
  }
  .traveler-encounter-dialog .enc-actions {
    display: flex;
    gap: 8px;
    margin-top: 4px;
  }
  .traveler-encounter-dialog .enc-actions button {
    flex: 1;
    padding: 6px 0;
    font-size: 0.9em;
    cursor: pointer;
    border-radius: 4px;
  }
  .traveler-encounter-dialog .enc-actions .btn-accept {
    background: var(--color-bg-btn-success, #2d6e2d);
    color: #fff;
    border-color: transparent;
  }
  .traveler-encounter-dialog .enc-actions .btn-decline {
    background: var(--color-bg-btn-danger, #6e2d2d);
    color: #fff;
    border-color: transparent;
  }
</style>

<div class="enc-header">
  {{#if img}}
    <img class="enc-portrait" src="{{img}}" alt="{{name}}">
  {{else}}
    <div class="enc-portrait-placeholder">⚔</div>
  {{/if}}

  <div class="enc-info">
    <p class="enc-name">{{name}}</p>
    <div class="enc-meta">
      {{#if environment}}<span><i class="fa-solid fa-tree"></i> {{environment}}</span><br>{{/if}}
      {{#if tableName}}<span><i class="fa-solid fa-dice"></i> {{tableName}}</span>{{/if}}
      {{#if label}}<br><span><i class="fa-solid fa-tag"></i> {{label}}</span>{{/if}}
      {{#if regenCount}}<br><span class="enc-regen-badge">Rerolled ×{{regenCount}}</span>{{/if}}
    </div>
  </div>
</div>

<div class="enc-actions">
  <button type="button" class="btn-accept" data-action="accept">
    <i class="fa-solid fa-check"></i> Accept
  </button>

  {{#if canRegen}}
  <button type="button" data-action="regenerate">
    <i class="fa-solid fa-dice"></i> Regenerate
  </button>
  {{/if}}

  <button type="button" class="btn-decline" data-action="decline">
    <i class="fa-solid fa-xmark"></i> Decline
  </button>
</div>
