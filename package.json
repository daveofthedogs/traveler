{
  "name": "traveler",
  "version": "2.0.0",
  "description": "Foundry VTT travel-route module",
  "type": "module",
  "private": true,
  "scripts": {
    "audit:ci": "npm audit --audit-level=high",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:integration": "node scripts/run-quench.js",
    "test:inspect": "cross-env TRAVELER_KEEP_WORLD=true node scripts/run-quench.js",
    "foundry:wait": "node scripts/foundry-wait.js",
    "foundry:bootstrap": "node scripts/ci-bootstrap.js",
    "playwright:install": "playwright install chromium",
    "foundry:up": "docker compose --env-file .env -f docker/compose.test.yml up -d",
    "foundry:stop": "docker compose --env-file .env -f docker/compose.test.yml stop",
    "foundry:start": "docker compose --env-file .env -f docker/compose.test.yml start",
    "foundry:logs": "docker compose --env-file .env -f docker/compose.test.yml logs -f foundry",
    "foundry:down": "docker compose --env-file .env -f docker/compose.test.yml down",
    "foundry:down:clean": "docker compose --env-file .env -f docker/compose.test.yml down -v",
    "foundry:reset": "npm run foundry:down:clean && npm run foundry:up && npm run foundry:logs",
    "world:clean": "node scripts/world-clean.js",
    "traveler:package": "node scripts/package-traveler.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@vitest/coverage-v8": "^4.1.8",
    "cross-env": "^10.1.0",
    "playwright": "^1.44.0",
    "vitest": "^4.1.8"
  }
}
